# ── Django ───────────────────────────────────────────────
SECRET_KEY=generate-a-fresh-50-byte-hex-key-for-production
DEBUG=False
ALLOWED_HOSTS=funding.richat-partners.com,www.richat-partners.com
FRONTEND_URL=https://funding.richat-partners.com

# ── Database ─────────────────────────────────────────────
POSTGRES_DB=richat_db
POSTGRES_USER=richat_user
POSTGRES_PASSWORD=use-a-long-random-production-password
POSTGRES_HOST=db
POSTGRES_PORT=5432

# ── Redis ────────────────────────────────────────────────
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2
CHANNEL_LAYERS_BACKEND=redis://redis:6379/3
REDIS_CACHE_URL=redis://redis:6379/4

# ── JWT ──────────────────────────────────────────────────
ACCESS_TOKEN_LIFETIME_MINUTES=15
REFRESH_TOKEN_LIFETIME_DAYS=7

# ── Email (SendGrid in production) ───────────────────────
EMAIL_HOST=smtp.sendgrid.net
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=apikey
EMAIL_HOST_PASSWORD=your-sendgrid-api-key-here
DEFAULT_FROM_EMAIL=noreply@richat-partners.com

# ── Storage: S3 / R2 (optional) ──────────────────────────
DEFAULT_FILE_STORAGE=storages.backends.s3boto3.S3Boto3Storage
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
AWS_S3_ENDPOINT_URL=
AWS_S3_REGION_NAME=auto

# ── Sentry (optional) ────────────────────────────────────
SENTRY_DSN=

# ── Files / uploads ──────────────────────────────────────
MAX_FILE_SIZE_MB=10
SIGNED_URL_EXPIRY_SECONDS=3600

# ── Scraping (Selenium) ──────────────────────────────────
SCRAPING_DELAY_SECONDS=2
SCRAPING_MAX_PAGES_DEFAULT=5
CHROME_BINARY_PATH=/usr/bin/chromium
CHROMEDRIVER_PATH=/usr/bin/chromedriver

# ── CORS (prod — leave False) ────────────────────────────
CORS_ALLOW_ALL_ORIGINS=False

# ── Frontend build args (baked at build time) ────────────
VITE_API_URL=https://funding.richat-partners.com
VITE_WS_URL=wss://funding.richat-partners.com