# ── Django ───────────────────────────────────────────────
SECRET_KEY=replace-me-generate-with-secrets-token-hex-50
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,backend
FRONTEND_URL=http://localhost:5173

# ── Database ─────────────────────────────────────────────
POSTGRES_DB=richat_db
POSTGRES_USER=richat_user
POSTGRES_PASSWORD=replace-me-with-a-strong-password
POSTGRES_HOST=db
POSTGRES_PORT=5432

# ── Redis ────────────────────────────────────────────────
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2
CHANNEL_LAYERS_BACKEND=redis://redis:6379/3
REDIS_CACHE_URL=redis://redis:6379/4

# ── JWT ──────────────────────────────────────────────────
ACCESS_TOKEN_LIFETIME_MINUTES=15
REFRESH_TOKEN_LIFETIME_DAYS=7

# ── Email (console backend for dev) ──────────────────────
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=noreply@richat.mr

# ── Files / uploads ──────────────────────────────────────
MAX_FILE_SIZE_MB=10
SIGNED_URL_EXPIRY_SECONDS=3600

# ── Scraping (Selenium) ──────────────────────────────────
SCRAPING_DELAY_SECONDS=2
SCRAPING_MAX_PAGES_DEFAULT=5
CHROME_BINARY_PATH=/usr/bin/chromium
CHROMEDRIVER_PATH=/usr/bin/chromedriver

# ── CORS (dev only) ──────────────────────────────────────
CORS_ALLOW_ALL_ORIGINS=True

# ── Frontend build args (prod) ───────────────────────────
VITE_API_URL=
VITE_WS_URL=