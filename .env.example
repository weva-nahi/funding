# ── Django ───────────────────────────────────────────────────────────────────
# Generate a real key: python -c "import secrets; print(secrets.token_urlsafe(50))"
SECRET_KEY=CHANGE_ME_TO_A_RANDOM_50_CHAR_STRING
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
FRONTEND_URL=http://localhost:5173

# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_DB=richat_db
POSTGRES_USER=richat_user
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_HOST=db
POSTGRES_PORT=5432

# ── Redis ─────────────────────────────────────────────────────────────────────
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2
CHANNEL_LAYERS_BACKEND=redis://redis:6379/3
REDIS_CACHE_URL=redis://redis:6379/4

# ── JWT ───────────────────────────────────────────────────────────────────────
ACCESS_TOKEN_LIFETIME_MINUTES=15
REFRESH_TOKEN_LIFETIME_DAYS=7

# ── Email ─────────────────────────────────────────────────────────────────────
# Development: prints emails to backend logs (look for the verification link)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
# Production: use SMTP
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your_email@gmail.com
EMAIL_HOST_PASSWORD=your_app_password
DEFAULT_FROM_EMAIL=noreply@richat.mr

# ── Files / Uploads ───────────────────────────────────────────────────────────
MAX_FILE_SIZE_MB=10
SIGNED_URL_EXPIRY_SECONDS=3600

# ── Scraping ──────────────────────────────────────────────────────────────────
SCRAPING_DELAY_SECONDS=2
SCRAPING_MAX_PAGES_DEFAULT=5
CHROME_BINARY_PATH=/usr/bin/chromium
CHROMEDRIVER_PATH=/usr/bin/chromedriver

# ── CORS ──────────────────────────────────────────────────────────────────────
# Set True only in development if you need it
CORS_ALLOW_ALL_ORIGINS=False

# ── Frontend Build Args (production only) ────────────────────────────────────
VITE_API_URL=http://localhost:8000
VITE_WS_URL=ws://localhost:8000

# ── Production Only ───────────────────────────────────────────────────────────
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_STORAGE_BUCKET_NAME=
# AWS_S3_ENDPOINT_URL=
# SENTRY_DSN=