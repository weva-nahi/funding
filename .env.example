# =========================================================
# Richat Funding Tracker - Environment Configuration (local dev)
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# =========================================================

# =========================================================
# Django
# =========================================================
# Generate with: python -c "import secrets; print(secrets.token_hex(64))"
SECRET_KEY=your-secret-key-here-generate-with-python-secrets

DEBUG=True

# Comma-separated list of allowed hosts
ALLOWED_HOSTS=localhost,127.0.0.1

# Full URL of the frontend (used in emails)
FRONTEND_URL=http://localhost:5173

# =========================================================
# MySQL Database (run natively or via Memurai-style local service)
# =========================================================
MYSQL_DATABASE=richat_db
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_HOST=localhost
MYSQL_PORT=3306

# =========================================================
# Redis (logically partitioned by DB index — see README for setup)
# DB 1 -> Celery Broker
CELERY_BROKER_URL=redis://localhost:6379/1
# DB 2 -> Celery Results
CELERY_RESULT_BACKEND=redis://localhost:6379/2
# DB 3 -> Django Channels
CHANNEL_LAYERS_BACKEND=redis://localhost:6379/3
# DB 4 -> Django Cache
REDIS_CACHE_URL=redis://localhost:6379/4

# =========================================================
# JWT Authentication
# =========================================================
ACCESS_TOKEN_LIFETIME_MINUTES=15
REFRESH_TOKEN_LIFETIME_DAYS=7

# =========================================================
# Email (SMTP) — use the console backend for local dev
# =========================================================
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.your-provider.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@domain.com
EMAIL_HOST_PASSWORD=your-smtp-app-password
DEFAULT_FROM_EMAIL=noreply@richat.mr

# =========================================================
# File Uploads
# =========================================================
MAX_FILE_SIZE_MB=5
SIGNED_URL_EXPIRY_SECONDS=3600
MAX_IMAGE_PIXELS=25000000
MAX_IMAGE_DIMENSION_PX=8000

# =========================================================
# Selenium / Scraping (only needed for the OECD scraper)
# =========================================================
SCRAPING_DELAY_SECONDS=2
# Leave CHROMEDRIVER_PATH empty to auto-download a matching driver via
# webdriver-manager (recommended); set it only if you manage chromedriver yourself.
CHROME_BINARY_PATH=C:\Program Files\Google\Chrome\Application\chrome.exe
CHROMEDRIVER_PATH=

# =========================================================
# CORS (True for local development)
# =========================================================
CORS_ALLOW_ALL_ORIGINS=True

# =========================================================
# Frontend Build Variables
# =========================================================
VITE_API_URL=http://localhost:8000
VITE_WS_URL=ws://localhost:8000

# =========================================================
# Retention Policies
# =========================================================
AUTH_TOKEN_RETENTION_DAYS=7
AUDIT_LOG_RETENTION_MONTHS=6
