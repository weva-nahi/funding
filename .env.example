# =========================================================
# Richat Funding Tracker - Environment Configuration
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# =========================================================

# =========================================================
# Django
# =========================================================
# Generate with: python -c "import secrets; print(secrets.token_hex(64))"
SECRET_KEY=your-secret-key-here-generate-with-python-secrets

# Set to False in production
DEBUG=False

# Comma-separated list of allowed hosts
ALLOWED_HOSTS=localhost,127.0.0.1,your-domain.com

# Full URL of the frontend (used in emails)
FRONTEND_URL=https://your-domain.com

# =========================================================
# PostgreSQL Database
# =========================================================
POSTGRES_DB=richat_db
POSTGRES_USER=richat_user
POSTGRES_PASSWORD=your-strong-database-password
POSTGRES_HOST=db
POSTGRES_PORT=5432

# =========================================================
# Redis (logically partitioned by DB index)
# DB 1 -> Celery Broker
CELERY_BROKER_URL=redis://redis:6379/1
# DB 2 -> Celery Results
CELERY_RESULT_BACKEND=redis://redis:6379/2
# DB 3 -> Django Channels
CHANNEL_LAYERS_BACKEND=redis://redis:6379/3
# DB 4 -> Django Cache
REDIS_CACHE_URL=redis://redis:6379/4

# =========================================================
# JWT Authentication
# =========================================================
ACCESS_TOKEN_LIFETIME_MINUTES=15
REFRESH_TOKEN_LIFETIME_DAYS=7

# =========================================================
# Email (SMTP)
# =========================================================
# Options: django.core.mail.backends.smtp.EmailBackend (production)
#          django.core.mail.backends.console.EmailBackend (development)
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.your-provider.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@domain.com
# App password or SMTP password (not your login password)
EMAIL_HOST_PASSWORD=your-smtp-app-password
DEFAULT_FROM_EMAIL=noreply@your-domain.com

# =========================================================
# File Uploads
# =========================================================
MAX_FILE_SIZE_MB=5
SIGNED_URL_EXPIRY_SECONDS=3600
MAX_IMAGE_PIXELS=25000000
MAX_IMAGE_DIMENSION_PX=8000

# =========================================================
# Selenium / Scraping (only needed for scraping worker)
# =========================================================
SCRAPING_DELAY_SECONDS=2
CHROME_BINARY_PATH=/usr/bin/chromium
CHROMEDRIVER_PATH=/usr/bin/chromedriver

# =========================================================
# CORS (set True only for local development)
# =========================================================
CORS_ALLOW_ALL_ORIGINS=False

# =========================================================
# Frontend Build Variables
# =========================================================
VITE_API_URL=
VITE_WS_URL=

# =========================================================
# Production: S3/R2 Storage (optional)
# =========================================================
# DEFAULT_FILE_STORAGE=storages.backends.s3boto3.S3Boto3Storage
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key
# AWS_STORAGE_BUCKET_NAME=your-bucket-name
# AWS_S3_ENDPOINT_URL=https://your-endpoint.r2.cloudflarestorage.com
# AWS_S3_REGION_NAME=auto

# =========================================================
# Sentry Error Tracking (optional, production)
# =========================================================
# SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# =========================================================
# Retention Policies
# =========================================================
AUTH_TOKEN_RETENTION_DAYS=7
AUDIT_LOG_RETENTION_MONTHS=6